# board-oss configuration (Story 2.1)
# All settings are environment variables with safe defaults — copy to `.env` or set
# in your process manager. Empty/whitespace values are treated as UNSET (defaults
# apply). The zero-config defaults boot a working, localhost-only, no-AI instance.

# --- Server ---
# Port to listen on.
PORT=3141
# Bind address. Default 127.0.0.1 (localhost-only — see Story 2.4 reverse-proxy
# posture). Do NOT set to 0.0.0.0 unless you front board-oss with a reverse proxy.
HOST=127.0.0.1

# --- Data ---
# Persistent data root (SQLite DB + screenshots live here). Story 2.2 roots all
# paths under this dir.
DATA_DIR=./data

# --- Capture ---
# Path to a system Chromium/Chrome binary. Optional — Story 2.3 autodetects on
# Linux when unset.
# CHROME_PATH=/usr/bin/chromium

# --- LLM provider (optional; unset = no-AI, enrichment disabled) ---
# CLI agent id for the subprocess provider (claude / codex / cursor-agent).
# LLM_AGENT=claude
# Model name (HttpProvider or CLI).
# LLM_MODEL=
# OpenAI-compatible base URL (HttpProvider).
# LLM_BASE_URL=https://api.openai.com/v1
# API key (secret — never logged; redacted in serialized config).
# LLM_API_KEY=

# Legacy prototype aliases (still honored; LLM_* takes precedence):
#   BOARD_ANALYSIS_AGENT -> LLM_AGENT
#   BOARD_CLAUDE_MODEL / BOARD_CODEX_MODEL -> LLM_MODEL
